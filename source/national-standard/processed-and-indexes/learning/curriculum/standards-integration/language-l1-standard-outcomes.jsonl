{"standard_outcome_id":"std.sgmoe.eng.lp.early-literacy.001","source_id":"src.national_standard.singapore-moe-2020-english-language-primary.0783e34e","country_or_region":"Singapore","framework_name":"English Language Syllabus 2020 Primary","subject":"english","level_or_grade_band":"Lower Primary foundation emphasis","original_code":"Provision of a Strong Foundation","original_statement_summary":"Lower-primary English places stronger emphasis on oral accuracy and fluency, enjoyment of language, phonemic awareness, phonics, early literacy, vocabulary development, interaction, writing, and integration of receptive and productive skills.","domain":"early_literacy_foundation","competency_tags":["phonics","oral-fluency","interaction","integrated-skills"],"knowledge_tags":["phonemic-awareness","phonics","vocabulary","grammar"],"skill_tags":["notice-sounds","practice-oral-language","interact-in-group","connect-reading-writing"],"attitude_tags":["joy-of-learning","positive-disposition"],"relevance_to_l1":"high","source_location":"Singapore Primary English PDF, p.33","copyright_note":"summary only"}
{"standard_outcome_id":"std.ibpyp.lang.phase1-2.oral.001","source_id":"src.national_standard.ibpyp-pyp-subject-continuums-language-en.a9fd33ff","country_or_region":"International Baccalaureate","framework_name":"PYP Subject Continuums: Language","subject":"english","level_or_grade_band":"PYP Phase 1 to Phase 2 bridge","original_code":"Oral language, Phases 1-2","original_statement_summary":"Learners move from communicating needs and ideas with gestures, words, routines, and simple responses toward joining discussions, using personal-experience language, asking questions, taking turns, and using increasingly accurate sounds and grammar.","domain":"oral_language","competency_tags":["oral-language","listening","speaking","interaction"],"knowledge_tags":["sounds","words","sentences","personal-experience-language"],"skill_tags":["respond-with-action-or-words","ask-questions","take-turns","describe-events"],"attitude_tags":["relationship-building","confidence"],"relevance_to_l1":"high","source_location":"PYP language continuum PDF, pp.12,16-18","copyright_note":"summary only"}
{"standard_outcome_id":"std.ibpyp.lang.phase2.visual.001","source_id":"src.national_standard.ibpyp-pyp-subject-continuums-language-en.a9fd33ff","country_or_region":"International Baccalaureate","framework_name":"PYP Subject Continuums: Language","subject":"english","level_or_grade_band":"PYP Phase 2","original_code":"Visual language, Phase 2","original_statement_summary":"Learners connect visual information with experience, understand that text and illustrations work together, ask questions about visual meaning, and communicate information through media and modalities.","domain":"visual_language","competency_tags":["viewing","presenting","multimodal-literacy"],"knowledge_tags":["visual-texts","illustrations","digital-iconography","symbols"],"skill_tags":["interpret-visuals","ask-about-visual-meaning","create-visual-text","connect-text-and-image"],"attitude_tags":["empathy","curiosity"],"relevance_to_l1":"medium","source_location":"PYP language continuum PDF, pp.13,20-22","copyright_note":"summary only"}
