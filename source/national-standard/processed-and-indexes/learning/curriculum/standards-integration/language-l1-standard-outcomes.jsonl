{"standard_outcome_id":"std.china2022.eng.l1.input-interaction.001","source_id":"src.national_standard.china-2022-6-2022.6496b8a0","country_or_region":"China","framework_name":"义务教育英语课程标准（2022年版）","subject":"english","level_or_grade_band":"preparatory and Level 1 bridge; formal Level 1 is a later primary reference","original_code":"预备级与一级语言实践相关要求","original_statement_summary":"Early English learning should provide abundant visual, listening, speaking, imitation, and routine interaction experiences before expecting independent written accuracy.","domain":"listening_speaking","competency_tags":["listening","speaking","interaction","imitation"],"knowledge_tags":["classroom-language","daily-expressions","sound-meaning-links"],"skill_tags":["listen-and-respond","imitate-and-use","participate-in-routine"],"attitude_tags":["interest","confidence","willingness-to-communicate"],"relevance_to_l1":"high","source_location":"China 2022 English DOCX, preparatory guidance and Level 1 language practice sections","copyright_note":"summary only"}
{"standard_outcome_id":"std.china2022.eng.l1.language-skills.001","source_id":"src.national_standard.china-2022-6-2022.6496b8a0","country_or_region":"China","framework_name":"义务教育英语课程标准（2022年版）","subject":"english","level_or_grade_band":"Level 1, G3-G4 reference; usable as a cautious L1 orientation only","original_code":"语言技能内容要求（一级）","original_statement_summary":"Learners understand simple classroom instructions, use pictures and context to understand short texts, exchange personal or family information, express likes and feelings, and copy or produce short supported language.","domain":"language_skills","competency_tags":["receptive-skills","expressive-skills","multimodal-understanding"],"knowledge_tags":["personal-information","family","school","daily-life"],"skill_tags":["follow-instruction","predict-from-picture","simple-exchange","copy-or-write-short-language"],"attitude_tags":["participation","willingness-to-communicate"],"relevance_to_l1":"high","source_location":"China 2022 English DOCX, Level 1 language skills tables","copyright_note":"summary only"}
{"standard_outcome_id":"std.china2022.eng.l1.vocabulary-grammar.001","source_id":"src.national_standard.china-2022-6-2022.6496b8a0","country_or_region":"China","framework_name":"义务教育英语课程标准（2022年版）","subject":"english","level_or_grade_band":"Level 1, G3-G4 reference; L1 textbook provides supported bridge tasks","original_code":"词汇知识、语法知识内容要求（一级）","original_statement_summary":"Learners connect word sound, form, meaning, and use through objects, pictures, and context, and use common simple sentence patterns to describe people, things, actions, preferences, and needs.","domain":"vocabulary_grammar","competency_tags":["vocabulary-in-context","sentence-pattern-use","grammar-in-use"],"knowledge_tags":["word-form-meaning-use","simple-sentences","present-tense-exposure"],"skill_tags":["name-with-context","substitute-in-frame","describe-person-object-action"],"attitude_tags":["contextual-learning"],"relevance_to_l1":"high","source_location":"China 2022 English DOCX, Level 1 vocabulary and grammar tables","copyright_note":"summary only"}
