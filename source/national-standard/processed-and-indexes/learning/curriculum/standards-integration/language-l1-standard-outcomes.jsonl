{"standard_outcome_id":"std.sgmoe.eng.lp.listening-viewing.001","source_id":"src.national_standard.singapore-moe-2020-english-language-primary.0783e34e","country_or_region":"Singapore","framework_name":"English Language Syllabus 2020 Primary","subject":"english","level_or_grade_band":"Lower Primary, P1-P2","original_code":"Listening and Viewing progression","original_statement_summary":"Lower-primary learners develop attentive listening and viewing dispositions, recognize sounds and words in context, use contextual clues, and respond to texts for understanding and enjoyment.","domain":"listening_viewing","competency_tags":["listening","viewing","positive-disposition"],"knowledge_tags":["sounds","words-in-context","spoken-texts","contextual-clues"],"skill_tags":["attend","recognize-key-words","respond-to-text","use-context-clues"],"attitude_tags":["empathy","respect","enjoyment"],"relevance_to_l1":"high","source_location":"Singapore Primary English PDF, pp.19-20","copyright_note":"summary only"}
{"standard_outcome_id":"std.sgmoe.eng.lp.reading-viewing.001","source_id":"src.national_standard.singapore-moe-2020-english-language-primary.0783e34e","country_or_region":"Singapore","framework_name":"English Language Syllabus 2020 Primary","subject":"english","level_or_grade_band":"Lower Primary, P1-P2","original_code":"Reading and Viewing progression","original_statement_summary":"Lower-primary learners build beginning reading and viewing accuracy, fluency, word recognition, positive reading disposition, and literal or inferential comprehension through text and visual clues.","domain":"reading_viewing","competency_tags":["early-reading","viewing","word-recognition","comprehension"],"knowledge_tags":["print","visual-cues","text-purpose","literal-meaning"],"skill_tags":["recognize-words","use-context-clues","predict","respond-to-text"],"attitude_tags":["reading-enjoyment"],"relevance_to_l1":"high","source_location":"Singapore Primary English PDF, pp.21-22","copyright_note":"summary only"}
{"standard_outcome_id":"std.sgmoe.eng.lp.speaking-representing.001","source_id":"src.national_standard.singapore-moe-2020-english-language-primary.0783e34e","country_or_region":"Singapore","framework_name":"English Language Syllabus 2020 Primary","subject":"english","level_or_grade_band":"Lower Primary, P1-P2","original_code":"Speaking and Representing progression","original_statement_summary":"Lower-primary learners learn basic spoken-language features, speak or represent for different purposes, participate respectfully in discussion, and produce short recounting, entertaining, instructing, or responding texts.","domain":"speaking_representing","competency_tags":["speaking","representing","purposeful-communication","discussion"],"knowledge_tags":["spoken-language-features","purpose-audience-context"],"skill_tags":["speak-with-support","represent-ideas","participate-respectfully","monitor-speech"],"attitude_tags":["confidence","respect"],"relevance_to_l1":"high","source_location":"Singapore Primary English PDF, pp.23-24","copyright_note":"summary only"}
